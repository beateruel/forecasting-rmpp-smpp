# ========================
# Python compiled files
# ========================
__pycache__/
*.pyc
*.pyo
*.pyd

# ========================
# Virtual environments (do not upload)
# ========================
.env          # environment variables (credentials, local paths)
venv/         # standard virtual environment
.env/         # alternative env folder

# ========================
# Config backups and old versions
# ========================
config_*.json  # older config versions
backup/*        # backup folder

# ========================
# Old pipeline versions
# ========================
src/pipeline_v*.py
backup

# ========================
# Input data
# ========================
input_full
input/*              
!input/RMPP_input.csv      
input/SMPP_input.csv  

# ========================
# Outputs
# ========================
output/

# ========================
# Logs
# ========================
*.log

# ========================
# IDE / system files
# ========================
.vscode/
.idea/
.vs/              
*.vsidx           
.DS_Store
Thumbs.db        

# ========================
# Notebook checkpoints
# ========================
.ipynb_checkpoints/

# ========================
# Temporary files
# ========================
*.tmp
*.bak
